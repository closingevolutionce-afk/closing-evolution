# Anthropic API — utilisée par l'Arena du Roleplay et le Simulateur d'Objections
# pour faire jouer un vrai prospect à l'IA (claude-sonnet-5 / claude-haiku-4-5).
ANTHROPIC_API_KEY=votre_cle_api_ici

# Supabase — comptes closers, progression, XP, badges, dashboard coach.
# Project Settings → API dans ton projet Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role — secrète, usage serveur uniquement (attribution XP, actions coach).
SUPABASE_SERVICE_ROLE_KEY=

# Emails autorisés à accéder à l'espace coach (séparés par des virgules).
ADMIN_EMAILS=chirinemessalti3@gmail.com
